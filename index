<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BritMax Streaming</title>
    
    <style>
        /* 1. THE DARK NEON STYLE */
        body {
            background: radial-gradient(circle at top, #050510 0%, #000000 100%);
            color: #ffffff;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            min-height: 100vh;
            overflow-x: hidden;
        }

        header {
            padding: 30px 50px;
            background: rgba(0, 0, 0, 0.8);
            border-bottom: 3px solid #6a0dad; /* Dark Neon Purple */
            box-shadow: 0 4px 20px rgba(106, 13, 173, 0.4);
            text-align: center;
        }

        h1 {
            margin: 0;
            font-size: 3.5rem;
            background: linear-gradient(45deg, #FFD700, #FF007F); /* Gold to Pink */
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
            letter-spacing: 6px;
            filter: drop-shadow(0 0 8px rgba(255, 0, 127, 0.5));
        }

        /* The Grid */
        #catalog {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 30px;
            padding: 50px;
        }

        /* Movie Card Logic */
        .movie-card {
            position: relative;
            background: #0a0a1a;
            border-radius: 8px;
            border: 2px solid #1a1a40; /* Dark Blue */
            overflow: hidden;
            cursor: pointer;
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .movie-card:hover {
            transform: scale(1.07);
            box-shadow: 0 0 15px rgba(138, 43, 226, 0.8), 0 0 30px rgba(255, 0, 127, 0.4);
            border-color: #FF007F; /* Neon Pink */
        }

        .movie-card img {
            width: 100%;
            aspect-ratio: 2/3;
            object-fit: cover;
            display: block;
        }

        /* Dark Neon Overlay */
        .card-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, #12002b 20%, transparent 100%);
            padding: 20px;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .movie-card:hover .card-overlay {
            opacity: 1;
        }

        .card-overlay h3 {
            margin: 0;
            color: #FFD700; /* Neon Gold */
            font-size: 1.1rem;
        }

        .card-overlay p {
            margin: 5px 0 0;
            color: #00d4ff; /* Dark Neon Blue */
            font-size: 0.85rem;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <header>
        <h1>BritMax</h1>
    </header>

    <main id="catalog">
        <!-- Movies will be injected here by the script below -->
    </main>

    <script>
        /* 2. THE WEB-APP CONNECTION */
        // PASTE YOUR DEPLOYED GOOGLE APPS SCRIPT URL HERE
        const API_URL = "PASTE_YOUR_APPS_SCRIPT_URL_HERE";

        async function fetchMovies() {
            try {
                const response = await fetch(API_URL);
                const data = await response.json();
                const container = document.getElementById('catalog');

                data.forEach(movie => {
                    const card = document.createElement('div');
                    card.className = 'movie-card';

                    // Using your exact CAPITALIZED headers from the sheet
                    card.innerHTML = `
                        <img src="${movie.Poster_URL}" alt="${movie.Title}">
                        <div class="card-overlay">
                            <h3>${movie.Title}</h3>
                            <p>${movie.Genre} • ${movie.Rating}</p>
                        </div>
                    `;

                    // Launch Rumble Embed on click
                    card.onclick = () => {
                        const embedUrl = `https://rumble.com/embed/${movie.Rumble_Embed_ID}/`;
                        window.open(embedUrl, "_blank", "width=800,height=450");
                    };

                    container.appendChild(card);
                });
            } catch (error) {
                console.error("BritMax Feed Error:", error);
            }
        }

        fetchMovies();
    </script>
</body>
</html>
